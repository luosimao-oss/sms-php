{
    "name": "luosimao/sms-php",
    "description": "Luosimao SMS PHP SDK",
    "keywords": [
        "sms",
        "luosimao",
        "luosimao-sdk"
    ],
    "type": "library",
    "require": {
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "jichen",
            "email": "jichen@luosimao.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Luosimao\\SmsSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable"
}
